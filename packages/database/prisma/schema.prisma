generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// created_by/updated_by/deleted_by are audit-only pointers, deliberately not
// modeled as Prisma relations (no enforced FK) to avoid a back-reference
// array on User for every audited table.
model Tenant {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  status    String    @default("ACTIVE")
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by") @db.Uuid

  memberships TenantMembership[]
  roles       Role[]

  classrooms        Classroom[]
  children          Child[]
  enrollments       Enrollment[]
  guardians         Guardian[]
  childGuardians    ChildGuardian[]
  staff             Staff[]
  attendanceRecords Attendance[]
  invoices          Invoice[]
  invoiceLineItems  InvoiceLineItem[]
  payments          Payment[]

  @@index([status])
  @@map("tenants")
}

model User {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String
  passwordHash String    @map("password_hash")
  status       String    @default("ACTIVE")
  tokenVersion Int       @default(0) @map("token_version")
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by") @db.Uuid

  memberships         TenantMembership[]
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]

  staff     Staff[]
  guardians Guardian[]

  @@index([status])
  @@map("users")
}

model Role {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  key       String
  name      String
  tenantId  String?   @map("tenant_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant      Tenant?            @relation(fields: [tenantId], references: [id])
  memberships TenantMembership[]

  @@map("roles")
}

model TenantMembership {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  roleId          String    @map("role_id") @db.Uuid
  status          String    @default("INVITED")
  inviteTokenHash String?   @map("invite_token_hash")
  inviteExpiresAt DateTime? @map("invite_expires_at")
  invitedAt       DateTime? @map("invited_at")
  activatedAt     DateTime? @map("activated_at")
  revokedAt       DateTime? @map("revoked_at")
  createdBy       String?   @map("created_by") @db.Uuid
  updatedBy       String?   @map("updated_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  deletedBy       String?   @map("deleted_by") @db.Uuid

  user   User   @relation(fields: [userId], references: [id])
  tenant Tenant @relation(fields: [tenantId], references: [id])
  role   Role   @relation(fields: [roleId], references: [id])

  @@index([tenantId])
  @@index([userId])
  @@index([status])
  @@map("tenant_memberships")
}

model RefreshToken {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  tokenHash         String    @unique @map("token_hash")
  tokenVersion      Int       @map("token_version")
  expiresAt         DateTime  @map("expires_at")
  revokedAt         DateTime? @map("revoked_at")
  replacedByTokenId String?   @unique @map("replaced_by_token_id") @db.Uuid
  userAgent         String?   @map("user_agent")
  ipAddress         String?   @map("ip_address") @db.Inet
  createdAt         DateTime  @default(now()) @map("created_at")

  user            User          @relation(fields: [userId], references: [id])
  replacedByToken RefreshToken? @relation("RefreshTokenChain", fields: [replacedByTokenId], references: [id])
  replacesToken   RefreshToken? @relation("RefreshTokenChain")

  @@index([userId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_reset_tokens")
}

// ---------------------------------------------------------------------------
// Domain model: enrollment, staffing, attendance, billing.
// See docs/architecture/domain-model.md — the single source of truth for
// this section. Partial/expression unique indexes noted below are
// deliberately not expressed here (Prisma DSL can't represent them) and are
// deferred to raw SQL in a future migration, same pattern as
// users_email_unique_active etc. in the initial identity migration.
// ---------------------------------------------------------------------------

model Classroom {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String
  capacity  Int
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by") @db.Uuid

  tenant            Tenant       @relation(fields: [tenantId], references: [id])
  enrollments       Enrollment[]
  staff             Staff[]
  attendanceRecords Attendance[]

  @@index([tenantId])
  @@map("classrooms")
}

model Child {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  firstName   String    @map("first_name")
  lastName    String    @map("last_name")
  dateOfBirth DateTime  @map("date_of_birth") @db.Date
  gender      String?
  photoUrl    String?   @map("photo_url")
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   String?   @map("deleted_by") @db.Uuid

  tenant      Tenant          @relation(fields: [tenantId], references: [id])
  enrollments Enrollment[]
  guardians   ChildGuardian[]
  attendance  Attendance[]
  invoices    Invoice[]

  @@index([tenantId])
  @@map("children")
}

// Historized placement record. A child's *current* classroom/status is the
// row where endDate IS NULL, never a mutable field on Child itself.
model Enrollment {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  childId       String    @map("child_id") @db.Uuid
  classroomId   String?   @map("classroom_id") @db.Uuid
  status        String
  startDate     DateTime  @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  createdReason String?   @map("created_reason")
  endedReason   String?   @map("ended_reason")
  createdBy     String?   @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedBy     String?   @map("deleted_by") @db.Uuid

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  child     Child      @relation(fields: [childId], references: [id])
  classroom Classroom? @relation(fields: [classroomId], references: [id])

  // Partial unique index enrollments_child_id_open_unique (child_id, WHERE
  // end_date IS NULL AND deleted_at IS NULL) and CHECK constraint
  // enrollments_date_range_valid live in migration
  // 20260720125319_add_enrollment_constraints - not expressible in Prisma DSL.
  @@index([tenantId])
  @@index([childId])
  @@index([classroomId])
  @@map("enrollments")
}

model Guardian {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String?   @map("user_id") @db.Uuid
  firstName String    @map("first_name")
  lastName  String    @map("last_name")
  phone     String?
  email     String?
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  deletedBy String?   @map("deleted_by") @db.Uuid

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  user     User?           @relation(fields: [userId], references: [id])
  children ChildGuardian[]
  invoices Invoice[]

  // Partial unique index guardians_tenant_user_unique_active (tenant_id,
  // user_id, WHERE deleted_at IS NULL) lives in migration add_domain_model -
  // at most one active Guardian profile per user, per tenant. Not a global
  // UNIQUE(user_id) - the same user may legitimately have profiles in
  // different tenants.
  @@index([tenantId])
  @@index([userId])
  @@map("guardians")
}

// Relationship-specific facts (relationshipType, contact flags) live here,
// on the pairing, not on Guardian - the same person could relate differently
// to two different children.
model ChildGuardian {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  childId            String    @map("child_id") @db.Uuid
  guardianId         String    @map("guardian_id") @db.Uuid
  relationshipType   String    @map("relationship_type")
  isPrimaryContact   Boolean   @default(false) @map("is_primary_contact")
  isEmergencyContact Boolean   @default(false) @map("is_emergency_contact")
  canPickup          Boolean   @default(false) @map("can_pickup")
  createdBy          String?   @map("created_by") @db.Uuid
  updatedBy          String?   @map("updated_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")
  deletedBy          String?   @map("deleted_by") @db.Uuid

  tenant   Tenant   @relation(fields: [tenantId], references: [id])
  child    Child    @relation(fields: [childId], references: [id])
  guardian Guardian @relation(fields: [guardianId], references: [id])

  // Partial unique, deferred to migration SQL:
  // UNIQUE (child_id, guardian_id) WHERE deleted_at IS NULL
  @@index([tenantId])
  @@index([childId])
  @@index([guardianId])
  @@map("child_guardians")
}

model Staff {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  userId      String?   @map("user_id") @db.Uuid
  classroomId String?   @map("classroom_id") @db.Uuid
  position    String?
  hireDate    DateTime? @map("hire_date") @db.Date
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   String?   @map("deleted_by") @db.Uuid

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  user      User?      @relation(fields: [userId], references: [id])
  classroom Classroom? @relation(fields: [classroomId], references: [id])

  // Partial unique index staff_tenant_user_unique_active (tenant_id,
  // user_id, WHERE deleted_at IS NULL) lives in migration add_domain_model -
  // at most one active Staff profile per user, per tenant. Not a global
  // UNIQUE(user_id) - the same user may legitimately have profiles in
  // different tenants.
  @@index([tenantId])
  @@index([userId])
  @@index([classroomId])
  @@map("staff")
}

// checkedInBy/checkedOutBy are dedicated, written-once actor references -
// unlike createdBy/updatedBy, they can't be silently overwritten by an
// unrelated correction to the row later.
model Attendance {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  childId      String    @map("child_id") @db.Uuid
  classroomId  String?   @map("classroom_id") @db.Uuid
  date         DateTime  @db.Date
  checkInTime  DateTime? @map("check_in_time") @db.Time
  checkOutTime DateTime? @map("check_out_time") @db.Time
  status       String
  checkedInBy  String?   @map("checked_in_by") @db.Uuid
  checkedOutBy String?   @map("checked_out_by") @db.Uuid
  createdBy    String?   @map("created_by") @db.Uuid
  updatedBy    String?   @map("updated_by") @db.Uuid
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  deletedAt    DateTime? @map("deleted_at")
  deletedBy    String?   @map("deleted_by") @db.Uuid

  tenant    Tenant     @relation(fields: [tenantId], references: [id])
  child     Child      @relation(fields: [childId], references: [id])
  classroom Classroom? @relation(fields: [classroomId], references: [id])

  @@unique([childId, date])
  @@index([tenantId])
  @@index([childId])
  @@index([classroomId])
  @@map("attendance")
}

model Invoice {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String    @map("tenant_id") @db.Uuid
  childId            String    @map("child_id") @db.Uuid
  billedToGuardianId String    @map("billed_to_guardian_id") @db.Uuid
  status             String
  totalAmount        Decimal   @map("total_amount") @db.Decimal(12, 2)
  createdBy          String?   @map("created_by") @db.Uuid
  updatedBy          String?   @map("updated_by") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")
  deletedAt          DateTime? @map("deleted_at")
  deletedBy          String?   @map("deleted_by") @db.Uuid

  tenant           Tenant            @relation(fields: [tenantId], references: [id])
  child            Child             @relation(fields: [childId], references: [id])
  billedToGuardian Guardian          @relation(fields: [billedToGuardianId], references: [id])
  lineItems        InvoiceLineItem[]
  payments         Payment[]

  @@index([tenantId])
  @@index([childId])
  @@index([billedToGuardianId])
  @@map("invoices")
}

model InvoiceLineItem {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  invoiceId   String    @map("invoice_id") @db.Uuid
  description String
  quantity    Decimal   @db.Decimal(10, 2)
  unitAmount  Decimal   @map("unit_amount") @db.Decimal(12, 2)
  totalAmount Decimal   @map("total_amount") @db.Decimal(12, 2)
  createdBy   String?   @map("created_by") @db.Uuid
  updatedBy   String?   @map("updated_by") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  deletedBy   String?   @map("deleted_by") @db.Uuid

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
  @@map("invoice_line_items")
}

model Payment {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  invoiceId     String    @map("invoice_id") @db.Uuid
  amount        Decimal   @db.Decimal(12, 2)
  paymentMethod String    @map("payment_method")
  paidAt        DateTime  @map("paid_at")
  createdBy     String?   @map("created_by") @db.Uuid
  updatedBy     String?   @map("updated_by") @db.Uuid
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  deletedBy     String?   @map("deleted_by") @db.Uuid

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  invoice Invoice @relation(fields: [invoiceId], references: [id])

  @@index([tenantId])
  @@index([invoiceId])
  @@map("payments")
}
